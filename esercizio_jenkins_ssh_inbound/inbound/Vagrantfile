Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "agent-inbound"
  config.vm.network "private_network", ip: "192.168.56.40"

  config.vm.provider "virtualbox" do |vb|
    vb.memory = 2048
    vb.cpus = 2
  end

  config.vm.provision "shell", inline: <<-SHELL
    apt-get update
    apt-get install -y openjdk-21-jre-headless curl
    useradd -m -s /bin/bash jenkins-agent
    mkdir -p /home/jenkins-agent/work
    chown -R jenkins-agent:jenkins-agent /home/jenkins-agent
  SHELL
end
